# Committed, non-secret defaults. Real API keys go in .env.local (gitignored).
#
# Prisma datasource. SQLite for the foundation phase (zero local setup).
# To switch to Postgres later: change provider in prisma/schema.prisma to
# "postgresql" and set this to a postgres:// connection string here (or in
# .env.local).
DATABASE_URL="file:./dev.db"
