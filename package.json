{
  "name": "trademaxxing",
  "version": "0.1.0",
  "private": true,
  "description": "AI-assisted paper-trading platform for forex/commodities (XAU/USD first). Foundation phase: schema, provider interfaces, shared types.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/lib/engine/__tests__/*.test.ts\" \"src/lib/backtest/__tests__/*.test.ts\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "tsx scripts/seed.ts",
    "pull:candles": "tsx scripts/pull-real-candles.ts",
    "reset:candles": "tsx scripts/reset-real-candles.ts",
    "detect": "tsx scripts/detect-signals.ts",
    "backtest": "tsx scripts/backtest.ts"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@prisma/client": "^5.22.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "dotenv": "^16.4.5",
    "postcss": "^8.4.39",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
