# Copy this file to .env.local and fill in real values.
#   cp .env.example .env.local
#
# .env.local is gitignored — never commit real keys.

# --- Database -------------------------------------------------------------
# SQLite (default for the foundation phase). Already set in the committed .env;
# override here only if you want a different location or a Postgres URL.
#
#   SQLite:    file:./dev.db
#   Postgres:  postgresql://user:password@localhost:5432/trademaxxing?schema=public
DATABASE_URL="file:./dev.db"

# --- Market data: Twelve Data --------------------------------------------
# Free tier ~8 requests/minute. Get a key at https://twelvedata.com/
TWELVE_DATA_API_KEY="your-twelve-data-api-key"

# --- LLM: Anthropic -------------------------------------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY="your-anthropic-api-key"
